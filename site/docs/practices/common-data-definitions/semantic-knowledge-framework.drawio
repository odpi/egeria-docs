        </mxCell>
        <mxCell id="26" value="The name that an employee wants to be known as." style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#ffffff;fontSize=13;align=left;verticalAlign=top;fontStyle=2;spacingLeft=2;spacingRight=2;" parent="1" vertex="1">
