        </mxCell>
        <mxCell id="31" value="Or is this the employment contract Id - need to check what happens if re-hire." style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#ffffff;fontSize=13;align=left;verticalAlign=top;fontStyle=2;spacingLeft=2;spacingRight=2;" parent="1" vertex="1">
          <mxGeometry x="556" y="260" width="265" height="60" as="geometry" />
        </mxCell>
        <mxCell id="33" value="Need to split up into first name, middle names, last name.&amp;nbsp; Seems common to all people. Legal name vs known name?" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#ffffff;fontSize=13;align=left;verticalAlign=top;fontStyle=2;spacingLeft=2;spacingRight=2;" parent="1" vertex="1">
