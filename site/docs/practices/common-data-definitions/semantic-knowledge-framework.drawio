        </mxCell>
        <mxCell id="28" value="Includes contractors?&amp;nbsp;" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#ffffff;fontSize=13;align=left;verticalAlign=top;fontStyle=2;spacingLeft=2;spacingRight=2;" parent="1" vertex="1">
